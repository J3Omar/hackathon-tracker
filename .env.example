# Facebook Credentials (حساب احتياطي)
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password
FB_PROXY=http://user:pass@ip:port

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
TARGET_EMAILS=email1@example.com,email2@example.com


# LM Studio Configuration
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions

# Search Keywords (separated by comma)
SEARCH_KEYWORDS=hackathon,هاكاثون,مسابقة برمجية

# Target Pages (Facebook page URLs, separated by comma)
TARGET_PAGES=https://www.facebook.com/GDGDelta,https://www.facebook.com/IEEEZagazig

# Location filter
LOCATION_KEYWORDS=زقازيق,الدقهلية,delta,mansoura,المنصورة
