# ============================================================
# Facebook Credentials
# ============================================================
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password
FB_PROXY=http://user:pass@ip:port

# ============================================================
# Telegram Bot Configuration
# ============================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================================
# Email Configuration
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
TARGET_EMAILS=email1@example.com,email2@example.com

# ============================================================
# LM Studio Configuration
# ============================================================
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions

# ============================================================
# Search Keywords — Arabic + English, broad coverage
# Add more comma-separated terms as needed
# ============================================================
SEARCH_KEYWORDS=هاكاثون,هاكثون,hackathon,مسابقة برمجية,مسابقة تقنية,تحدي برمجي,تحدي تقني,مسابقة الابتكار,innovation challenge,كود ماراثون,code marathon,datathon,داتاثون,ideathon,startup weekend,CTF مسابقة,ICPC,سجل الآن هاكاثون,التسجيل مفتوح,hackathon egypt,hackathon cairo,hackathon zagazig,hackathon delta,coding competition egypt,tech competition egypt,AI challenge egypt,GDG hackathon,IEEE competition egypt

